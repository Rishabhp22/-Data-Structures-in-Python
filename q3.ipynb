   "source": [
    "s = input(\"Enter string\")\n",
    "rev = s[::-1]\n",
    "\n",
    "if s == rev:\n",
    "    print(\"Yes, The String is Palindrome.\")\n",
    "else:\n",
    "    print('No')"
   ]
  }
