   ],
   "source": [
    "s = 'Rishab'\n",
    "visited = ''\n",
    "is_unique = True\n",
    "\n",
    "for ch in s:\n",
    "    if ch in visited:\n",
    "        is_unique = False\n",
    "        break\n",
    "    visited += ch\n",
    "   \n",
    "if is_unique:\n",
    "    print(\"All Char is unique\")\n",
    "else:\n",
    "    print(\"String does not have all unique char\")"
   ]
  }
 ],
